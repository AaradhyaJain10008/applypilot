# =============================================================================
# Career Command Center — environment variables (example)
# Copy this file to ".env" and fill in YOUR own values.
# Never commit your real .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# AI Providers (configure at least ONE — you can mix and match)
# ---------------------------------------------------------------------------
# Provider chain (ordered comma-separated). The app walks the chain in order
# and uses the first one that has a key configured AND succeeds.
AI_PROVIDER=groq

# Groq (free tier, very fast). Sign up at https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL_ANALYZE=llama-3.3-70b-versatile
GROQ_MODEL_DEFAULT=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Cerebras (free tier, OpenAI-compatible). https://cloud.cerebras.ai
CEREBRAS_API_KEY=
CEREBRAS_MODEL_ANALYZE=llama-3.3-70b
CEREBRAS_MODEL_DEFAULT=llama-3.3-70b
CEREBRAS_MODEL_FAST=llama3.1-8b

# Google Gemini. https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.0-flash
GEMINI_MODEL_CANDIDATES=

# GitHub Models (free for developers). PAT must include `models:read` scope.
# https://github.com/settings/tokens
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL_ANALYZE=gpt-4o-mini
GITHUB_MODELS_MODEL_DEFAULT=gpt-4o-mini

# Ollama (local, optional). Install: https://ollama.com
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:latest

# Provider chain order per task (fallbacks if a provider fails / is unkeyed).
# Allowed values: groq, cerebras, gemini, github, ollama
TASK_CHAIN_ANALYZE=groq,cerebras,gemini,github,ollama
TASK_CHAIN_DRAFT=groq,cerebras,gemini,github,ollama
TASK_CHAIN_NOTE=groq,cerebras,gemini,github,ollama
TASK_CHAIN_ASK=groq,cerebras,gemini,github,ollama
TASK_CHAIN_COVER=groq,cerebras,gemini,github,ollama

# ---------------------------------------------------------------------------
# Email sending (optional — leave blank to disable email sending entirely)
# ---------------------------------------------------------------------------
# Use a Gmail App Password (NOT your regular password):
# https://support.google.com/accounts/answer/185833
SENDER_EMAIL=
EMAIL_APP_PASSWORD=

# ---------------------------------------------------------------------------
# App configuration paths (defaults are fine — override only if needed)
# ---------------------------------------------------------------------------
# Profile / resume / settings — point to your own JSON files.
PROFILE_CONFIG_PATH=config/profile.json
RESUME_CONFIG_PATH=config/resume_personas.json
APP_SETTINGS_PATH=config/app_settings.json

# Local runtime data (auto-created if missing).
JOB_TRACKER_PATH=data/job_tracker.csv
AI_USAGE_LOG_PATH=data/ai_usage_log.csv
SCHEDULED_EMAILS_FILE=data/scheduled_emails.json

# Where the app looks for resume PDFs (relative to the project root).
RESUME_DIR=resumes

# ---------------------------------------------------------------------------
# Apify Discovery / Enrichment (optional)
# ---------------------------------------------------------------------------
APIFY_TOKEN=
APIFY_ACTOR_DISCOVERY_ID=
APIFY_ACTOR_ENRICHMENT_ID=
APIFY_TIMEOUT_S=180
APIFY_MAX_RETRIES=2

# Budget guardrails
APIFY_MAX_COST_PER_RUN_USD=0.50
APIFY_MONTHLY_FREE_TIER_USD=5.00
APIFY_MIN_REMAINING_FREE_TIER_USD=0.50
APIFY_ESTIMATED_CU_PER_RUN=0.20
APIFY_USD_PER_COMPUTE_UNIT=0.25

# Job posting scout (Step 1 "Scout analyst jobs" button) — reuse your LinkedIn Jobs
# Actor here, or reuse APIFY_ACTOR_DISCOVERY_ID if that actor already scrapes postings.
APIFY_ACTOR_LINKEDIN_JOBS_ID=
# Separate Greenhouse board scraper Actor ID (omit to skip GH and only run LinkedIn).
APIFY_ACTOR_GREENHOUSE_JOBS_ID=

# Default keyword is analyst (single token). Optionally override SCOUT_JOB_KEYWORD_DEFAULT.
SCOUT_JOB_KEYWORD_DEFAULT=analyst

# Caps job rows returned per Actor run (raised budget estimate in ApifySafeStop logic).
SCOUT_JOB_MAX_ITEMS=80

# LinkedIn timeframe hack: builds https://www.linkedin.com/jobs/search/...&f_TPR=r<seconds>
# r86400 = past 24h. User preference in-app is ~10000 seconds (~2.8h) — override as you like.
SCOUT_LINKEDIN_POSTED_SECONDS=10000

# Optional geo filter (copy from LinkedIn URL when you run the same search in the browser).
# United States is often geoId=103644278 — omit to leave location as LinkedIn default.
SCOUT_LINKEDIN_GEO_ID=

# Optional Actor-specific overrides (merged into run_input dicts — keys depend on Actor).
APIFY_LINKEDIN_JOBS_INPUT_JSON=
APIFY_GREENHOUSE_JOBS_INPUT_JSON=

# ---------------------------------------------------------------------------
# Daily quotas + scheduler tuning (sensible defaults)
# ---------------------------------------------------------------------------
DAILY_ANALYZE_SOFT_CAP=30
DAILY_ANALYZE_HARD_CAP=45
EMAIL_SCHEDULER_POLL_SECONDS=20

# ---------------------------------------------------------------------------
# Flask host / port (override only if 5001 conflicts on your machine)
# ---------------------------------------------------------------------------
FLASK_HOST=127.0.0.1
FLASK_PORT=5001
